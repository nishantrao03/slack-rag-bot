generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  slack_member_id String @id

  created_at      DateTime @default(now())

  projects         ProjectMember[]
  uploaded_docs    Document[]
  created_projects Project[] @relation("ProjectCreator")
}

model Project {
  id          String   @id
  name        String
  created_by  String
  created_at  DateTime @default(now())

  creator     User @relation("ProjectCreator", fields: [created_by], references: [slack_member_id])
  members     ProjectMember[]
  channels    Channel[]
  documents   Document[]
  threads     Thread[]
}

model ProjectMember {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       Role
  joined_at  DateTime @default(now())

  project    Project @relation(fields: [project_id], references: [id])
  user       User    @relation(fields: [user_id], references: [slack_member_id])

  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
}

model Channel {
  channel_id String   @id
  name       String
  project_id String
  canvas_id String?
  is_private Boolean
  created_at DateTime @default(now())

  project    Project @relation(fields: [project_id], references: [id])

  @@index([project_id])
}

model Thread {
  thread_id  String   @id
  project_id String
  created_at DateTime @default(now())

  project    Project @relation(fields: [project_id], references: [id])

  @@index([project_id])
}

model Document {
  document_id String   @id @default(uuid())
  name        String
  link        String?
  project_id  String
  uploaded_by String
  is_private  Boolean  @default(false)
  created_at  DateTime @default(now())

  project     Project @relation(fields: [project_id], references: [id])
  uploader    User    @relation(fields: [uploaded_by], references: [slack_member_id])

  @@index([project_id])
  @@index([uploaded_by])
}

enum Role {
  manager
  member
}